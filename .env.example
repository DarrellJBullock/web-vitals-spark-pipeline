# Root directory for all pipeline data (raw/processed/curated/reports).
# Defaults to the project root if unset.
DATA_ROOT=.

# Spark session tuning (safe defaults for a laptop-scale demo run).
SPARK_APP_NAME=web-vitals-spark-pipeline
SPARK_MASTER=local[*]
SPARK_SHUFFLE_PARTITIONS=8
SPARK_LOG_LEVEL=WARN

# Regression detection thresholds (overrides the defaults in src/config/settings.py).
LCP_REGRESSION_PCT=0.20
LCP_POOR_THRESHOLD_MS=2500
CLS_REGRESSION_DELTA=0.05
CLS_POOR_THRESHOLD=0.1
INP_REGRESSION_PCT=0.20
INP_POOR_THRESHOLD_MS=200
TTFB_REGRESSION_PCT=0.25
TTFB_POOR_THRESHOLD_MS=800
